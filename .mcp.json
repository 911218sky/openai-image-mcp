{
  "mcpServers": {
    "openai-image-mcp": {
      "command": "bash",
      "args": ["./scripts/start-mcp.sh"],
      "cwd": ".",
      "env": {
        "OPENAI_BASE_URL": "https://api.openai.com/v1",
        "OPENAI_IMAGE_MODEL": "gpt-image-2",
        "OPENAI_IMAGE_TRANSPORT": "auto",
        "OPENAI_TIMEOUT_SECONDS": "1200"
      },
      "env_vars": [
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL",
        "OPENAI_IMAGE_MODEL",
        "OPENAI_IMAGE_TRANSPORT",
        "OPENAI_TIMEOUT_SECONDS"
      ]
    }
  }
}
