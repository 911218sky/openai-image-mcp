# Legacy OpenAI-compatible settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TRANSPORT=auto
OPENAI_TIMEOUT_SECONDS=1200

# Optional provider registry. Keep the local providers.toml outside Git.
OPENAI_IMAGE_CONFIG=

# Used by the Gemini-native provider example.
GEMINI_API_KEY=
