OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TRANSPORT=auto
OPENAI_TIMEOUT_SECONDS=1200
OPENAI_IMAGE_ALLOW_INSECURE_BASE_URL=false

# Optional Streamable HTTP MCP transport.
OPENAI_IMAGE_MCP_TRANSPORT=stdio
OPENAI_IMAGE_MCP_HOST=127.0.0.1
OPENAI_IMAGE_MCP_PORT=8000
OPENAI_IMAGE_MCP_PATH=/mcp
# Add the hostname:port used by your MCP client when it is not loopback.
OPENAI_IMAGE_MCP_ALLOWED_HOSTS=

# Optional public image URL enrichment. Leave empty for local file output.
OPENAI_IMAGE_OUTPUT_DIR=
OPENAI_IMAGE_PUBLIC_IMAGES_ROOT=
OPENAI_IMAGE_PUBLIC_URL_PREFIX=/images
OPENAI_IMAGE_EMBED_MAX_BYTES=8388608
